# Copy to .env and fill in the values you need.
# The benchmark harness reads from .env at project root.

# Image generation (already configured in comic/.env, duplicated here for the
# demo asset generator)
FAL_API_KEY=

# Anthropic API direct (separate from Claude Code CLI)
# Used by run_suite.py provider=anthropic-api for the A/B test that rules
# out Claude CLI quirks. Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API
# Used by run_suite.py provider=openai-api for the C test with GPT 5.5.
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
